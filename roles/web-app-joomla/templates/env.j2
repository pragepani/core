JOOMLA_SITE_NAME={{ JOOMLA_SITE_NAME }}
JOOMLA_ADMIN_USER={{ JOOMLA_USER }}
JOOMLA_ADMIN_USERNAME={{ JOOMLA_USER_NAME }}
JOOMLA_ADMIN_PASSWORD={{ JOOMLA_USER_PASSWORD | dotenv_quote }}
JOOMLA_ADMIN_EMAIL={{ JOOMLA_USER_EMAIL }}

{% if lookup('database', application_id, 'type') == 'mariadb' %}
# Database
JOOMLA_DB_HOST={{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}
JOOMLA_DB_USER={{ lookup('database', application_id, 'username') }}
JOOMLA_DB_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
JOOMLA_DB_NAME={{ lookup('database', application_id, 'name') }}
JOOMLA_DB_TYPE={{ JOOMLA_DB_CONNECTOR }}
{% endif %}

{% if lookup('config', application_id, 'services.sso.enabled') | bool %}
# OIDC SSO via the in-role plg_system_keycloak plugin.
# Modus 3: Force-Frontend, Local-Backup-Backend. The fallback hatch at
# /administrator?fallback=local can be disabled by flipping
# services.sso.oidc.fallback_enabled to false in this role's meta/services.yml.
JOOMLA_OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL }}
JOOMLA_OIDC_CLIENT_ID={{ OIDC.CLIENT.ID }}
JOOMLA_OIDC_CLIENT_SECRET={{ OIDC.CLIENT.SECRET | dotenv_quote }}
JOOMLA_OIDC_REDIRECT_URI={{ lookup('tls', application_id, 'url.base') }}/index.php?option=keycloak&task=callback
JOOMLA_OIDC_END_SESSION_URL={{ OIDC.CLIENT.LOGOUT_URL }}
JOOMLA_OIDC_FALLBACK_ENABLED={{ lookup('config', application_id, 'services.sso.oidc.fallback_enabled') | string | lower }}
JOOMLA_OIDC_GROUP_ADMIN=/{{ lookup('rbac_group_path', application_id=application_id, role='administrator') }}
JOOMLA_OIDC_GROUP_EDITOR=/{{ lookup('rbac_group_path', application_id=application_id, role='editor') }}
JOOMLA_OIDC_GROUP_USER=/roles/{{ application_id }}
{% endif %}
