APP_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
CANONICAL_DOMAIN={{ lookup('domain', application_id) | dotenv_quote }}
FEDIWALL_DEFAULT_SLUG={{ (FEDIWALL_WALLS | first).slug | dotenv_quote }}
FEDIWALL_WALL_SLUGS={{ (FEDIWALL_WALLS | map(attribute='slug') | list) | to_json | dotenv_quote }}

{# Service-gating registry. The biber-cross-fediverse
   scenarios gate on `mastodon` AND `friendica`; the per-wall
   reachability + CSP baseline scenarios gate on nothing. #}
MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

MASTODON_SERVICE_ENABLED={{ ('true' if 'web-app-mastodon' in group_names else 'false') }}
FRIENDICA_SERVICE_ENABLED={{ ('true' if 'web-app-friendica' in group_names else 'false') }}

{# Sibling base URLs the cross-fediverse scenarios target. Only
   exposed when the sibling is actually deployed; otherwise the
   service gate skips the scenario, so the value is unused. #}
{% if 'web-app-mastodon' in group_names %}
MASTODON_BASE_URL={{ lookup('tls', 'web-app-mastodon', 'url.base') | dotenv_quote }}
{% endif %}
{% if 'web-app-friendica' in group_names %}
FRIENDICA_BASE_URL={{ lookup('tls', 'web-app-friendica', 'url.base') | dotenv_quote }}
{% endif %}

BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}

PERSONA_BIBER_BLOCKED=true
PERSONA_ADMINISTRATOR_BLOCKED=true

# Service gate flags rendered for closure.
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}
MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}
# nocheck: playwright-service-gate — covered by sys-svc-mail integration tests, not the persona surface
EMAIL_SERVICE_ENABLED={{ lookup('config', application_id, 'services.email.enabled') | string | lower }}
# nocheck: playwright-service-gate — SSO surface; auth flow gated by Keycloak realm not Playwright env var
SSO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.sso.enabled') | string | lower }}
