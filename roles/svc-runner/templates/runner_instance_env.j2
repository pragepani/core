COMPOSE_PROJECT_NAME={{ runner_project_prefix }}-{{ runner_instance }}
INFINITO_RUNNER_PREFIX={{ runner_project_prefix }}-{{ runner_instance }}
# Each instance gets its own /24 keyed on the instance number so parallel
# runners on the same host never claim overlapping container IPs.
# INFINITO_* variants are preserved by load.sh setdefault semantics so the
# dev compose stack inside this runner uses the instance-specific subnet.
INFINITO_SUBNET=172.30.{{ runner_instance }}.0/24
INFINITO_GATEWAY=172.30.{{ runner_instance }}.1
INFINITO_DNS_IP=172.30.{{ runner_instance }}.53
INFINITO_IP4=172.30.{{ runner_instance }}.10
INFINITO_BIND_IP=172.30.{{ runner_instance }}.1
DOMAIN=infinito.example
DOMAIN_RE=infinito\.example
INVENTORY_DIR={{ RUNNER_INSTALL_DIR }}/{{ runner_instance }}/inventories/github
INFINITO_DOCKER_VOLUME={{ runner_docker_base }}/{{ runner_instance }}
INFINITO_PRESERVE_DOCKER_CACHE=true
INFINITO_CPUS={{ RUNNER_CPUS }}
RUNNER_NAME={{ runner_name }}-{{ runner_instance }}
RUNNER_LABELS={{ runner_labels }}
RUNNER_GITHUB_OWNER={{ RUNNER_GITHUB_OWNER }}
RUNNER_GITHUB_REPO={{ RUNNER_GITHUB_REPO }}
RUNNER_API_TOKEN={{ RUNNER_API_TOKEN }}
DOCKER_IN_CONTAINER={{ DOCKER_IN_CONTAINER | bool | lower }}
