# Postmarks runtime
PORT={{ container_port }}
NODE_ENV=production

# Postmarks uses express-session and refuses to start without an
# explicit `SESSION_SECRET`. Pull a deterministic value from the
# project's secret store so the rendered env is reproducible across
# deploys.
SESSION_SECRET={{ lookup('config', application_id, 'credentials.session_secret') | dotenv_quote }}
ADMIN_KEY={{ lookup('config', application_id, 'credentials.admin_key') | dotenv_quote }}

# Trusted-header SSO bridge (oauth2 SSO flavor). When proxy-gated, the
# sidecar oauth2-proxy authenticates against Keycloak and nginx overwrites
# the X-Forwarded-* identity headers; the bridge flips Postmarks' owner
# session. PROXY_HEADER_SSO_ADMIN_GROUP restricts the owner session to
# members of the application's administrator RBAC group.
PROXY_HEADER_SSO={{ POSTMARKS_SSO_PROXY_GATED | string | lower }}
PROXY_HEADER_SSO_ADMIN_GROUP={{ POSTMARKS_SSO_ADMIN_GROUP | dotenv_quote }}

