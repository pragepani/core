{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  application:
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        POSTMARKS_REPO_URL: "{{ POSTMARKS_REPO_URL }}"
        POSTMARKS_REF: "{{ POSTMARKS_REF }}"
        CONTAINER_PORT: "{{ container_port | string }}"
    image: "{{ POSTMARKS_IMAGE }}:{{ POSTMARKS_VERSION }}"
    container_name: "{{ POSTMARKS_CONTAINER }}"
    hostname: "{{ container_hostname }}"
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ http_port }}:{{ container_port }}"
{% include 'roles/sys-svc-container/templates/healthcheck/tcp.yml.j2' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{# `compose_volumes` declares the top-level `volumes:` map (redis,
   application data, etc.). Required when `services.sso.enabled`
   (flavor: oauth2) pulls in the redis sidecar; otherwise compose
   rejects the project with `service "redis" refers to undefined
   volume redis`. #}
{{ lookup('applications') | compose_volumes(
    application_id,
) }}

{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
