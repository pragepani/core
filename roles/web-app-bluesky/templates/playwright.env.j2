# Bluesky's OIDC integration is the variant-A+ login-broker (roles/web-app-bluesky/files/login-broker/);
# the OIDC marker keys off services.sso.enabled (oauth2-proxy sidecar is the user-facing OIDC
# entry point) and the LDAP marker keys off services.ldap.enabled (set by the LDAP variant in
# meta/variants.yml). RBAC is intentionally not mappable (PDS knows only "account exists / does not
# exist") and is documented as a SSO/RBAC exception in README.md per lifecycle.md. The social-app UI
# is mobile-first: the logout/account control lives behind a profile menu deep in the SPA, not in a
# top-level chrome bar that the persona-flow auth-surface check can reach. The bespoke "OIDC:
# oauth2-proxy + login-broker drop a Bluesky session into social-app via Keycloak (variant A+)" test
# already proves biber authenticates via the broker (verifies BSKY_STORAGE.accessJwt is present),
# and the bespoke LDAP variant test proves the same chain under LDAP federation. Both personas are
# therefore blocked at the generic dashboard → app → logout persona-flow level — the role's OIDC +
# LDAP tests carry the equivalent contract.

ADMIN_HANDLE={{ BLUESKY_ADMIN_HANDLE | dotenv_quote }}

ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}

ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}

APP_BASE_URL={{ lookup('tls', application_id, 'url.base') }}

BLUESKY_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}

CANONICAL_DOMAIN={{ lookup('domain', application_id) | dotenv_quote }}

# nocheck: playwright-service-gate — covered by sys-svc-mail integration tests, not the persona surface
EMAIL_SERVICE_ENABLED={{ lookup('config', application_id, 'services.email.enabled') | string | lower }}

LDAP_SERVICE_ENABLED={{ BLUESKY_LDAP_ENABLED | string | lower }}

# Service gate flags rendered for closure.
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}

MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}

NODE_TLS_REJECT_UNAUTHORIZED=0

OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}


PDS_BASE_URL={{ (lookup('tls', application_id, 'protocols.web') ~ '://' ~ BLUESKY_API_DOMAIN) | dotenv_quote }}

PERSONA_ADMINISTRATOR_BLOCKED=true

# See file header for the why.
PERSONA_BIBER_BLOCKED=true

SSO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.sso.enabled') | string | lower }}

