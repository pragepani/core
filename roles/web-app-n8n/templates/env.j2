# PostgreSQL
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST={{ lookup('database', application_id, 'host') }}
DB_POSTGRESDB_PORT={{ lookup('database', application_id, 'port') }}
DB_POSTGRESDB_DATABASE={{ lookup('database', application_id, 'name') }}
DB_POSTGRESDB_USER={{ lookup('database', application_id, 'username') }}
DB_POSTGRESDB_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}

# n8n core
N8N_PORT={{ N8N_INTERNAL_PORT }}
N8N_HOST={{ N8N_HOSTNAME }}
N8N_PROTOCOL={{ N8N_WEB_PROTOCOL }}
WEBHOOK_URL={{ N8N_WEB_PROTOCOL }}://{{ N8N_HOSTNAME }}/
N8N_ENCRYPTION_KEY={{ N8N_ENCRYPTION_KEY | dotenv_quote }}
# Trust the nginx/oauth2-proxy X-Forwarded-* headers one hop upstream.
N8N_PROXY_HOPS=1
GENERIC_TIMEZONE={{ HOST_TIMEZONE }}
TZ={{ HOST_TIMEZONE }}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
# SMTP
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST={{ email.host }}
N8N_SMTP_PORT={{ email.port }}
N8N_SMTP_USER={{ email.username }}
N8N_SMTP_PASS={{ email.password | dotenv_quote }}
N8N_SMTP_SENDER={{ email['from'] }}
{% endif %}
