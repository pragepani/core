ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}

ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}

BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}

BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}

SEAWEEDFS_FILER_URL={{ (lookup('tls', application_id, 'protocols.web') ~ '://' ~ lookup('config', application_id, 'server.domains.canonical.filer')) | dotenv_quote }}

SEAWEEDFS_MASTER_URL={{ (lookup('tls', application_id, 'protocols.web') ~ '://' ~ lookup('config', application_id, 'server.domains.canonical.master')) | dotenv_quote }}

SSO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.sso.enabled') | string | lower }}

# nocheck: playwright-service-gate
LDAP_SERVICE_ENABLED={{ lookup('config', application_id, 'services.ldap.enabled') | string | lower }}

# nocheck: playwright-service-gate
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}

# nocheck: playwright-service-gate
DASHBOARD_SERVICE_ENABLED={{ lookup('config', application_id, 'services.dashboard.enabled') | string | lower }}

# nocheck: playwright-service-gate
PROMETHEUS_SERVICE_ENABLED={{ lookup('config', application_id, 'services.prometheus.enabled') | string | lower }}

{% set buckets = [] %}
{% for role in group_names | select('match', '^web-app-') | reject('equalto', application_id) | list %}
{%   set objstore = lookup('objstore', role) %}
{%   if objstore.engine == 'seaweedfs' and objstore.shared %}
{%     set _ = buckets.append({'role': role, 'bucket': objstore.bucket}) %}
{%   endif %}
{% endfor %}
SEAWEEDFS_CONSUMER_BUCKETS={{ buckets | to_json | dotenv_quote }}
