##
# All environment variables defined here will only apply if you pass them
# to the OpenProject container in compose.yml under x-op-app -> environment.
# For the examples here this is already the case.
#
# Please refer to our documentation to see all possible variables:
#   https://www.openproject.org/docs/installation-and-operations/configuration/environment/
#
OPENPROJECT_HTTPS={{ lookup('tls', application_id, 'enabled') | string | lower }}
OPENPROJECT_HOST__NAME={{ lookup('domain',application_id) }}
OPENPROJECT_RAILS__RELATIVE__URL__ROOT=
IMAP_ENABLED=false
SECRET_KEY_BASE={{ lookup('config', application_id, 'credentials.secret_key_base') }}
OPENPROJECT_HSTS={{ lookup('tls', application_id, 'enabled') | string | lower }}
RAILS_CACHE_STORE: "memcache"
OPENPROJECT_CACHE__MEMCACHE__SERVER: "cache:11211"
OPENPROJECT_RAILS__RELATIVE__URL__ROOT: ""

{% if OPENPROJECT_HEADER_SSO_ENABLED | bool %}
# Header-based Single Sign-On (OpenProject core AuthSourceSSO concern).
# Emitted only when LDAP is also enabled: AuthSourceSSO resolves the header login
# exclusively via the LDAP auth source, so without it every login would fail.
# The trusted nginx<->app hop sends X-Remote-User as `login:secret`; the login
# half is the Keycloak preferred_username, resolved against the LDAP auth source.
OPENPROJECT_AUTH__SOURCE__SSO_HEADER={{ OPENPROJECT_SSO_HEADER }}
OPENPROJECT_AUTH__SOURCE__SSO_SECRET={{ OPENPROJECT_SSO_SECRET | dotenv_quote }}
OPENPROJECT_AUTH__SOURCE__SSO_OPTIONAL=true
{% if OPENPROJECT_SSO_LOGOUT_URL %}
OPENPROJECT_AUTH__SOURCE__SSO_LOGOUT__URL={{ OPENPROJECT_SSO_LOGOUT_URL }}
{% endif %}
{% endif %}

# Database
POSTGRES_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
DATABASE_URL="{{ lookup('database', application_id, 'url_full') }}?pool=20&encoding=unicode&reconnect=true"
DB_POOL="{{ OPENPROJECT_DB_POOL }}"
RAILS_MAX_THREADS="{{ OPENPROJECT_RAILS_MAX_THREADS }}"
RAILS_MIN_THREADS=4

{% if lookup('objstore', application_id, 'enabled') | bool %}
OPENPROJECT_ATTACHMENTS__STORAGE=fog
OPENPROJECT_DIRECT__UPLOADS=false
OPENPROJECT_FOG_DIRECTORY={{ lookup('objstore', application_id, 'bucket') }}
OPENPROJECT_FOG_CREDENTIALS_PROVIDER=AWS
OPENPROJECT_FOG_CREDENTIALS_AWS__ACCESS__KEY__ID={{ lookup('objstore', application_id, 'access_key') }}
OPENPROJECT_FOG_CREDENTIALS_AWS__SECRET__ACCESS__KEY={{ lookup('objstore', application_id, 'secret_key') | dotenv_quote }}
OPENPROJECT_FOG_CREDENTIALS_REGION={{ lookup('objstore', application_id, 'region') }}
OPENPROJECT_FOG_CREDENTIALS_HOST={{ lookup('objstore', application_id, 'host') }}
OPENPROJECT_FOG_CREDENTIALS_ENDPOINT={{ lookup('objstore', application_id, 'url') }}
OPENPROJECT_FOG_CREDENTIALS_PATH__STYLE=true
{% endif %}

# This Openproject Container isn't build for development environments
RAILS_ENV=production
