---
matrix_domain: {{ DOMAIN_PRIMARY }}
matrix_homeserver_implementation: synapse
matrix_playbook_docker_installation_enabled: false
matrix_playbook_migration_validated_version: "{{ MATRIX_MDAD_MIGRATION_VALIDATED_VERSION }}"

matrix_synapse_macaroon_secret_key: "{{ lookup('config', application_id, 'credentials.macaroon_secret_key') }}"
matrix_homeserver_generic_secret_key: "{{ lookup('config', application_id, 'credentials.macaroon_secret_key') }}"

# Synapse's default rc_login (burst 3, ~0.17/s) is too strict for the SSO E2E
# suite, where several personas/specs sign in back-to-back and exhaust the
# burst, leaving each later sign-in cycling consent <-> M_LIMIT_EXCEEDED.
matrix_synapse_rc_login:
  address:
    per_second: 1
    burst_count: 30
  account:
    per_second: 1
    burst_count: 30
  failed_attempts:
    per_second: 1
    burst_count: 30

{% if lookup('objstore', application_id, 'enabled') | bool %}
matrix_synapse_ext_synapse_s3_storage_provider_enabled: true
matrix_synapse_ext_synapse_s3_storage_provider_store_synchronous: true
matrix_synapse_ext_synapse_s3_storage_provider_config_bucket: "{{ lookup('objstore', application_id, 'bucket') }}"
matrix_synapse_ext_synapse_s3_storage_provider_config_region_name: "{{ lookup('objstore', application_id, 'region') }}"
matrix_synapse_ext_synapse_s3_storage_provider_config_endpoint_url: "{{ lookup('objstore', application_id, 'url') }}"
matrix_synapse_ext_synapse_s3_storage_provider_config_access_key_id: "{{ lookup('objstore', application_id, 'access_key') }}"
matrix_synapse_ext_synapse_s3_storage_provider_config_secret_access_key: "{{ lookup('objstore', application_id, 'secret_key') }}"
matrix_synapse_ext_synapse_s3_storage_provider_config_storage_class: STANDARD
{% endif %}

traefik_enabled: false
matrix_playbook_reverse_proxy_type: none

postgres_enabled: false
postgres_connection_hostname: "{{ MATRIX_POSTGRES_HOST }}"
postgres_connection_port: {{ MATRIX_POSTGRES_PORT }}
postgres_connection_username: "{{ MATRIX_POSTGRES_USER }}"
postgres_connection_password: "{{ MATRIX_POSTGRES_PASSWORD }}"

matrix_synapse_database_host: "{{ MATRIX_POSTGRES_HOST }}"
matrix_synapse_database_port: {{ MATRIX_POSTGRES_PORT }}
matrix_synapse_database_user: "{{ MATRIX_POSTGRES_USER }}"
matrix_synapse_database_password: "{{ MATRIX_POSTGRES_PASSWORD }}"
matrix_synapse_database_database: "{{ MATRIX_POSTGRES_DATABASE }}"

matrix_homeserver_container_network: host
matrix_addons_container_network: host
matrix_synapse_container_network: host
matrix_client_element_container_network: host
coturn_container_network: host
jitsi_web_container_network: host
jitsi_jvb_container_network: host
jitsi_prosody_container_network: host
jitsi_jicofo_container_network: host

matrix_livekit_jwt_service_container_port: 8030

{% if (TLS_MODE | lower) == 'self_signed' %}
matrix_synapse_container_extra_arguments:
  - "--mount type=bind,src={{ CA_TRUST.cert_host }},dst={{ MATRIX_CA_MOUNT_PATH }},ro"
  - "-e SSL_CERT_FILE={{ MATRIX_CA_MOUNT_PATH }}"
  - "-e REQUESTS_CA_BUNDLE={{ MATRIX_CA_MOUNT_PATH }}"
{% endif %}

{% if MATRIX_COTURN_SHARED %}
coturn_enabled: false
matrix_synapse_turn_uris:
  - "turn:{{ MATRIX_COTURN_HOST }}:{{ MATRIX_COTURN_STUN_TURN_PORT }}?transport=udp"
  - "turn:{{ MATRIX_COTURN_HOST }}:{{ MATRIX_COTURN_STUN_TURN_PORT }}?transport=tcp"
  - "turns:{{ MATRIX_COTURN_HOST }}:{{ MATRIX_COTURN_STUN_TURN_TLS_PORT }}?transport=udp"
  - "turns:{{ MATRIX_COTURN_HOST }}:{{ MATRIX_COTURN_STUN_TURN_TLS_PORT }}?transport=tcp"
matrix_synapse_turn_shared_secret: "{{ MATRIX_COTURN_AUTH_SECRET }}"
{% endif %}


valkey_enabled: false

exim_relay_enabled: {{ (not MATRIX_OUTBOUND_MAIL_ENABLED) | string | lower }}
matrix_synapse_email_enabled: {{ MATRIX_OUTBOUND_MAIL_ENABLED | string | lower }}
{% if MATRIX_OUTBOUND_MAIL_ENABLED %}
matrix_synapse_email_smtp_host: "{{ MATRIX_OUTBOUND_MAIL_HOST }}"
matrix_synapse_email_smtp_port: {{ MATRIX_OUTBOUND_MAIL_PORT }}
matrix_synapse_email_smtp_user: "{{ MATRIX_OUTBOUND_MAIL_USER }}"
matrix_synapse_email_smtp_pass: "{{ MATRIX_OUTBOUND_MAIL_PASS }}"
matrix_synapse_email_notif_from: "{{ ORGANIZATION }} Matrix <{{ MATRIX_OUTBOUND_MAIL_USER }}>"
{% endif %}

matrix_synapse_oidc_enabled: {{ MATRIX_OIDC_ENABLED | string | lower }}
{% if MATRIX_OIDC_ENABLED %}
matrix_synapse_oidc_providers:
  - idp_id: keycloak
    idp_name: "{{ OIDC.BUTTON_TEXT }}"
    discover: true
    issuer: "{{ OIDC.CLIENT.ISSUER_URL }}"
    client_id: "{{ OIDC.CLIENT.ID }}"
    client_secret: "{{ OIDC.CLIENT.SECRET }}"
    scopes:
      - openid
      - profile
      - email
    user_mapping_provider:
      config:
        localpart_template: !unsafe "{% raw %}{{ user.preferred_username }}{% endraw %}"
        display_name_template: !unsafe "{% raw %}{{ user.name }}{% endraw %}"
        email_template: !unsafe "{% raw %}{{ user.email }}{% endraw %}"
{% endif %}

matrix_synapse_ldap_enabled: {{ MATRIX_LDAP_ENABLED | string | lower }}
{% if MATRIX_LDAP_ENABLED %}
matrix_synapse_ext_password_provider_ldap_enabled: true
matrix_synapse_ext_password_provider_ldap_uri: "ldap://{{ LDAP.SERVER.DOMAIN }}:{{ LDAP.SERVER.PORT }}"
matrix_synapse_ext_password_provider_ldap_base: "{{ LDAP.DN.OU.USERS }}"
matrix_synapse_ext_password_provider_ldap_bind_dn: "{{ LDAP.DN.ADMINISTRATOR.DATA }}"
matrix_synapse_ext_password_provider_ldap_bind_password: "{{ LDAP.BIND_CREDENTIAL }}"
matrix_synapse_ext_password_provider_ldap_attributes_uid: "{{ LDAP.USER.ATTRIBUTES.ID }}"
matrix_synapse_ext_password_provider_ldap_attributes_mail: mail
matrix_synapse_ext_password_provider_ldap_attributes_name: givenName
{% endif %}

matrix_client_element_enabled: true
matrix_client_element_default_hs_url: "{{ MATRIX_SYNAPSE_URL }}"

matrix_appservice_irc_enabled: {{ MATRIX_BRIDGE.appservice_irc | default(false) | string | lower }}
matrix_heisenbridge_enabled: {{ MATRIX_BRIDGE.heisenbridge | default(false) | string | lower }}
matrix_hookshot_enabled: {{ MATRIX_BRIDGE.hookshot | default(false) | string | lower }}
matrix_appservice_discord_enabled: {{ MATRIX_BRIDGE.discord | default(false) | string | lower }}
matrix_mautrix_discord_enabled: {{ MATRIX_BRIDGE.mautrix_discord | default(false) | string | lower }}
matrix_mautrix_slack_enabled: {{ MATRIX_BRIDGE.mautrix_slack | default(false) | string | lower }}
matrix_mautrix_signal_enabled: {{ MATRIX_BRIDGE.mautrix_signal | default(false) | string | lower }}
matrix_mautrix_telegram_enabled: {{ MATRIX_BRIDGE.mautrix_telegram | default(false) | string | lower }}
matrix_mautrix_twitter_enabled: {{ MATRIX_BRIDGE.mautrix_twitter | default(false) | string | lower }}
matrix_mautrix_whatsapp_enabled: {{ MATRIX_BRIDGE.mautrix_whatsapp | default(false) | string | lower }}
matrix_mautrix_gitter_enabled: {{ MATRIX_BRIDGE.gitter | default(false) | string | lower }}

jitsi_enabled: {{ MATRIX_CONFERENCING_JITSI | string | lower }}
matrix_rtc_enabled: {{ MATRIX_CONFERENCING_ELEMENT_CALL | string | lower }}
