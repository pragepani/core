  matrix-mdad:
    container_name: matrix-mdad
    build:
      context: {{ application_id | abs_role_path_by_application_id }}/files/flavor/ansible/runner
      args:
        MATRIX_MDAD_RUNNER_BASE_IMAGE: {{ MATRIX_MDAD_RUNNER_BASE_IMAGE }}
        MATRIX_MDAD_RUNNER_BASE_VERSION: {{ MATRIX_MDAD_RUNNER_BASE_VERSION }}
        MATRIX_MDAD_RUNNER_DOCKER_CLI_IMAGE: {{ MATRIX_MDAD_RUNNER_DOCKER_CLI_IMAGE }}
        MATRIX_MDAD_RUNNER_DOCKER_CLI_VERSION: {{ MATRIX_MDAD_RUNNER_DOCKER_CLI_VERSION }}
    image: {{ MATRIX_MDAD_RUNNER_IMAGE }}
    restart: {{ DOCKER_RESTART_POLICY }}
    privileged: true
    cgroup: host
    stop_signal: SIGRTMIN+3
    environment:
      MATRIX_MDAD_PLAYBOOK_TAGS: "{{ MATRIX_MDAD_PLAYBOOK_TAGS }}"
    volumes:
      - {{ MATRIX_MDAD_DIR }}:/mdad
      - matrix_mdad_docker:/var/lib/docker
      - matrix_mdad_state:/var/lib/matrix-mdad
      - matrix_mdad_matrix:/matrix
      - /sys/fs/cgroup:/sys/fs/cgroup:rw
    tmpfs:
      - /run
      - /run/lock
      - /tmp
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ MATRIX_SYNAPSE_PORT }}:{{ MATRIX_SYNAPSE_PORT }}"
      - "{{ DOCKER_BIND_HOST }}:{{ MATRIX_ELEMENT_PORT }}:{{ MATRIX_ELEMENT_PORT }}"
      - "{{ DOCKER_BIND_HOST }}:{{ MATRIX_FEDERATION_PORT }}:{{ MATRIX_FEDERATION_PORT }}"
