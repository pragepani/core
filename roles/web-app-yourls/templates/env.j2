YOURLS_DB_HOST: "{{ lookup('database', application_id, 'host') }}"
YOURLS_DB_USER: "{{ lookup('database', application_id, 'username') }}"
YOURLS_DB_PASS: "{{ lookup('database', application_id, 'password') }}"
YOURLS_DB_NAME: "{{ lookup('database', application_id, 'name') }}"
YOURLS_SITE:    "{{ lookup('tls', application_id, 'url.base') }}"
YOURLS_USER:    "{{ YOURLS_USER }}"
YOURLS_PASS:    "{{ YOURLS_PASSWORD }}"
# Keep YOURLS private even behind oauth2-proxy so yourls_is_valid_user() runs
# and the trusted-header SSO shim (user/cache.php) authenticates each request.
YOURLS_PRIVATE: "true"
# Trusted-header SSO bridge gating (read by user/cache.php).
PROXY_HEADER_SSO: "{{ YOURLS_SSO_PROXY_GATED | string | lower }}"
PROXY_HEADER_SSO_ADMIN_GROUP: "{{ YOURLS_SSO_ADMIN_GROUP }}"
PROXY_HEADER_SSO_GATED_PATH: "{{ YOURLS_ADMIN_LOCATION }}"