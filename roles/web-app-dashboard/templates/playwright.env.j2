ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}

ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}

APP_BASE_URL={{ lookup('tls', DASHBOARD_APPLICATION_ID, 'url.base') }}

ASSET_SERVICE_ENABLED={{ lookup('config', application_id, 'services.asset.enabled') | string | lower }}

BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}

BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}

CANONICAL_DOMAIN={{ lookup('domain', application_id) | dotenv_quote }}

CDN_BASE_URL={{ lookup('tls', 'web-svc-cdn', 'url.base') | dotenv_quote }}

CDN_SERVICE_ENABLED={{ lookup('config', application_id, 'services.cdn.enabled') | string | lower }}

CSS_SERVICE_ENABLED={{ lookup('config', application_id, 'services.css.enabled') | string | lower }}

DASHBOARD_JS_BASE_URL={{ DASHBOARD_JS_BASE_URL | dotenv_quote }}

# Tile-reachability targets: every role declaring services.dashboard.{enabled,shared}. Spec parameterises one test per entry.
DASHBOARD_TARGET_ROLES_JSON={{ lookup('roles_with_service', 'dashboard') | to_json | dotenv_quote }}

LOGIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}

LOGIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}

LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}

MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}

OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}

PERSONA_ADMINISTRATOR_BLOCKED={{ (not (lookup('config', application_id, 'services.sso.enabled') | bool)) | string | lower }}

# With SSO disabled the dashboard renders no Login link, so persona helpers have no auth surface. Collapse to BLOCKED for a clean skip.
PERSONA_BIBER_BLOCKED={{ (not (lookup('config', application_id, 'services.sso.enabled') | bool)) | string | lower }}

PLATFORM_FAVICON_URL={{ DASHBOARD_PLATFORM_FAVICON_URL | dotenv_quote }}

# Resolved branding URLs from vars/main.yml. port-ui embeds reachable URLs so rendered img src and link href match exactly.
PLATFORM_LOGO_URL={{ DASHBOARD_PLATFORM_LOGO_URL | dotenv_quote }}

SIMPLEICONS_SERVICE_ENABLED={{ lookup('config', application_id, 'services.simpleicons.enabled') | string | lower }}

# Service gate flags rendered for closure.
SSO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.sso.enabled') | string | lower }}

