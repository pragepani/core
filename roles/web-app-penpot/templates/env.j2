# Penpot Configuration
PENPOT_PUBLIC_URI={{ PENPOT_PUBLIC_URI }}

# Flags configuration
PENPOT_FLAGS=enable-prepl-server enable-smtp{% if PENPOT_OIDC_ENABLED | bool %} enable-login-with-oidc enable-oidc-registration{% endif %}{% if PENPOT_LDAP_ENABLED | bool %} enable-login-with-ldap{% endif %}

# Backend  
PENPOT_SECRET_KEY={{ PENPOT_SECRET_KEY }}

# Database
PENPOT_DATABASE_USERNAME={{ PENPOT_DATABASE_USERNAME }}
PENPOT_DATABASE_PASSWORD={{ PENPOT_DATABASE_PASSWORD | dotenv_quote }}
PENPOT_DATABASE_URI={{ PENPOT_DATABASE_URI }}

# Postgres (for postgres container)
POSTGRES_INITDB_ARGS=--data-checksums
POSTGRES_DB={{ lookup('database', application_id, 'name') }}
POSTGRES_USER={{ lookup('database', application_id, 'username') }}
POSTGRES_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}

# Redis
PENPOT_REDIS_URI={{ PENPOT_REDIS_URI }}

# Assets storage
PENPOT_OBJECTS_STORAGE_BACKEND=fs
PENPOT_OBJECTS_STORAGE_FS_DIRECTORY=/opt/data/assets

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
# SMTP Configuration
PENPOT_SMTP_DEFAULT_FROM={{ email['from'] | dotenv_quote }}
PENPOT_SMTP_DEFAULT_REPLY_TO={{ email['from'] | dotenv_quote }}
PENPOT_SMTP_HOST={{ email.host }}
PENPOT_SMTP_PORT={{ email.port }}
PENPOT_SMTP_USERNAME={{ email.username | dotenv_quote }}
PENPOT_SMTP_PASSWORD={{ email.password | dotenv_quote }}
PENPOT_SMTP_TLS={{ email.tls | string | lower }}
{% endif %}

{% if PENPOT_OIDC_ENABLED | bool %}
# OIDC Configuration
PENPOT_OIDC_CLIENT_ID={{ OIDC.CLIENT.ID }}
PENPOT_OIDC_CLIENT_SECRET={{ OIDC.CLIENT.SECRET | dotenv_quote }}
PENPOT_OIDC_BASE_URI={{ OIDC.CLIENT.ISSUER_URL }}
# Explicit URIs (per memory note about discovery issues)
PENPOT_OIDC_AUTH_URI={{ OIDC.CLIENT.ISSUER_URL }}/protocol/openid-connect/auth
PENPOT_OIDC_TOKEN_URI={{ OIDC.CLIENT.ISSUER_URL }}/protocol/openid-connect/token
PENPOT_OIDC_USER_URI={{ OIDC.CLIENT.ISSUER_URL }}/protocol/openid-connect/userinfo
PENPOT_OIDC_SCOPES=openid profile email
PENPOT_OIDC_NAME=SSO with Infinito.nexus
{% endif %}

{% if PENPOT_LDAP_ENABLED | bool %}
# LDAP Configuration
PENPOT_LDAP_HOST={{ lookup('ldap', application_id, 'host') }}
PENPOT_LDAP_PORT={{ lookup('ldap', application_id, 'port') }}
PENPOT_LDAP_SSL={{ lookup('ldap', application_id, 'ssl') | string | lower }}
PENPOT_LDAP_STARTTLS={{ lookup('ldap', application_id, 'starttls') | string | lower }}
PENPOT_LDAP_BASE_DN={{ lookup('ldap', application_id, 'base_dn') }}
PENPOT_LDAP_BIND_DN={{ lookup('ldap', application_id, 'bind_dn') }}
PENPOT_LDAP_BIND_PASSWORD={{ lookup('ldap', application_id, 'bind_password') | dotenv_quote }}
PENPOT_LDAP_USER_QUERY=(&(|(uid=:username)(mail=:username))(objectClass=inetOrgPerson))
PENPOT_LDAP_ATTRS_USERNAME=uid
PENPOT_LDAP_ATTRS_EMAIL=mail
PENPOT_LDAP_ATTRS_FULLNAME=cn
{% endif %}

# Frontend
PENPOT_BACKEND_URI={{ PENPOT_BACKEND_URI }}
PENPOT_EXPORTER_URI={{ PENPOT_EXPORTER_URI }}
