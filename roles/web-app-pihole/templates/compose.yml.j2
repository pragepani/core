{% set container_port = 80 %}
{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
{% if lookup('sso', application_id, 'is_proxy_gated') and (TLS_MODE | lower) == 'self_signed' %}
  sso-proxy:
    # Self-signed TLS only: oauth2-proxy is a distroless Go binary; the platform
    # CA wrapper (with-ca-trust.sh) is skipped because there is no /bin/sh, and
    # Go ignores SSL_CERT_FILE. Pass the CA cert directly via --provider-ca-file
    # so oauth2-proxy trusts the internal Keycloak OIDC endpoint.
    command:
      - --config
      - /oauth2-proxy.cfg
      - --provider-ca-file
      - /tmp/infinito/ca/root-ca.crt
{% endif %}

  pihole:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ PIHOLE_IMAGE }}:{{ PIHOLE_VERSION }}"
    container_name: "{{ PIHOLE_CONTAINER }}"
    environment:
      TZ:               "{{ PIHOLE_TIMEZONE }}"
      WEBPASSWORD:      "{{ PIHOLE_PASSWORD }}"
      PIHOLE_DNS_:      "{{ PIHOLE_UPSTREAM_DNS }}"
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.pihole.ports.local.http') }}:80/tcp"
    cap_add:
      - NET_ADMIN
    volumes:
      - pihole_data:/etc/pihole
      - pihole_dnsmasq:/etc/dnsmasq.d
{% include 'roles/sys-svc-container/templates/healthcheck/tcp.yml.j2' %}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}

{{ lookup('applications') | compose_volumes(
    application_id,
    extra_volumes={
      'pihole_data':   {'name': PIHOLE_VOLUME_DATA},
      'pihole_dnsmasq': {'name': PIHOLE_VOLUME_DNSMASQ},
      'redis':         {}
    }
) }}
